{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "install",
      "detail": "Install the locked JavaScript dependencies",
      "type": "process",
      "command": "mise",
      "args": ["run", "install"],
      "problemMatcher": [],
      "presentation": {
        "clear": true,
        "close": true,
        "echo": true,
        "focus": false,
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false,
      },
      "icon": {
        "id": "cloud-download",
        "color": "terminal.ansiGreen",
      },
    },
    {
      "label": "check",
      "detail": "Run every required validation",
      "type": "process",
      "command": "mise",
      "args": ["run", "check"],
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true,
      },
      "presentation": {
        "clear": true,
        "close": false,
        "echo": true,
        "focus": false,
        "group": "test",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false,
      },
      "icon": {
        "id": "check-all",
        "color": "terminal.ansiGreen",
      },
    },
    {
      "label": "build",
      "detail": "Build the production Obsidian plugin bundle",
      "type": "process",
      "command": "mise",
      "args": ["run", "build"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true,
      },
      "presentation": {
        "clear": true,
        "close": true,
        "echo": true,
        "focus": false,
        "group": "build",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false,
      },
      "icon": {
        "id": "package",
        "color": "terminal.ansiGreen",
      },
    },
    {
      "label": "dev",
      "detail": "Rebuild the plugin bundle as source files change",
      "type": "process",
      "command": "mise",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".",
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building",
          "endsPattern": "Built",
        },
      },
      "presentation": {
        "clear": true,
        "close": true,
        "echo": true,
        "focus": false,
        "group": "dev",
        "panel": "dedicated",
        "reveal": "always",
        "showReuseMessage": false,
      },
      "icon": {
        "id": "circuit-board",
        "color": "terminal.ansiGreen",
      },
    },
  ],
}
