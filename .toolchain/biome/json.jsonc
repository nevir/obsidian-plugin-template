{
  "linter": {
    // https://biomejs.dev/linter/json/rules/
    "rules": {
      "suspicious": {
        // Disallow duplicate keys in object literals.
        "noDuplicateObjectKeys": "error"
      }
    }
  },

  "overrides": [
    {
      "includes": ["**/*.json*"],
      "assist": {
        "actions": {
          "source": {
            // It is context-dependent whether keys should be sorted.
            "useSortedKeys": "off"
          }
        }
      }
    }
  ]
}
